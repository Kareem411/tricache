{
  "name": "tricache",
  "version": "0.6.1",
  "description": "Three-tier Node.js cache: L1 smart RAM (adaptive LFU/LRU + Count-Min Sketch) → L1.5 NVMe disk spill → L2 Redis/Valkey. Includes AES-256-GCM at-rest encryption, WASM Bloom filter, Stale-While-Revalidate, and thundering-herd prevention.",
  "keywords": [
    "cache",
    "redis",
    "valkey",
    "lru",
    "lfu",
    "bloom-filter",
    "count-min-sketch",
    "swr",
    "stale-while-revalidate",
    "msgpack",
    "aes-256-gcm",
    "nextjs",
    "nodejs"
  ],
  "license": "MIT",
  "packageManager": "pnpm@11.3.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/serialize-worker.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/serialize-worker.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "node --expose-gc --import tsx/esm bench/benchmark.ts"
  },
  "dependencies": {
    "ioredis": "^5.11.0",
    "msgpackr": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "homepage": "https://github.com/Kareem411/TriCache#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kareem411/TriCache.git"
  }
}
